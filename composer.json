{
    "name": "automattic/style-guide-reviewer",
    "description": "Review post content against a brand style guide using the WordPress AI Client and Abilities API.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "composer/installers": "^1 || ^2"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "phpcsstandards/phpcsextra": "^1.2",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpstan/phpstan": "^2.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "StyleGuideReviewer\\": "includes/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpcbf": "phpcbf --standard=phpcs.xml.dist",
        "phpstan": "phpstan analyse --memory-limit=512M"
    }
}
